<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Suppress expected stack traces for malformed JSON and connection drop tests -->
    <logger name="com.quant.binancequotes.websocket.QuoteMessageParser" level="ERROR" />
    <logger name="com.quant.binancequotes.websocket.BinanceWebSocketClient" level="OFF" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>